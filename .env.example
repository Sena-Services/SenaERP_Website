# Environment Configuration
# Copy this file to .env.local for local development

# Frappe Backend URL
# Specify the full URL of your Frappe backend API
# Examples:
#   - Production: https://senamarketing.senaerp.com
#   - Local Development: http://localhost:8000
NEXT_PUBLIC_FRAPPE_URL=http://localhost:8000

# Frontend Application URL
# Where to redirect after environment selection
# Examples:
#   - Production: https://{sitename}
#   - Local Development: http://localhost:8080
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080
